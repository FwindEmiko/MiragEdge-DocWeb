# unified LF line endings for all text files
# orig first line was Chinese comment - git does not parse it
* text=auto eol=lf

# 显式指定 markdown YAML/JSON 也按文本
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ts text eol=lf
*.mts text eol=lf
*.vue text eol=lf

# 二进制文件保 true
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff2 binary
*.woff binary
*.ttf binary
